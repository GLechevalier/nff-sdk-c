/*
 * Copy this to wifi_secrets.h (same directory) and fill it in. wifi_secrets.h is gitignored.
 *
 * BLOB_URL must point at the 1 MiB blob served by the host profiler, on THIS machine's LAN
 * address — not localhost, which means nothing to the ESP32. The profiler prints the exact
 * URL to paste here when it starts up.
 */

#define WIFI_SSID "your-ssid"
#define WIFI_PASS "your-password"

// e.g. "http://192.168.1.42:8099/blob.bin"
#define BLOB_URL "http://<your-pc-lan-ip>:8099/blob.bin"
